---
import "../../styles/global.css";
import { listIssues } from "../../lib/issues.js";
import { url } from "../../lib/url.js";

const files = await listIssues();
const slugs = files.map(f => f.replace(/\.json$/, ""));
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Octozine · Archive</title>
  <link rel="alternate" type="application/atom+xml" title="Octozine" href={url("feed.xml")} />
</head>
<body>
  <main class="page">
    <header class="header">
      <div class="brand">
        <div class="mark">o</div>
        <div>
          <div class="brand-name">Octozine</div>
          <div class="brand-meta">Archive</div>
        </div>
      </div>
      <nav class="nav">
        <a href={url("/")}>Latest</a>
        <a href={url("/feed.xml")}>RSS</a>
      </nav>
    </header>
    <section class="archive-hero">
      <p class="kicker">Archive</p>
      <h1>Past issues</h1>
      <p>Each one ranked against your profile from scratch — same source pool, different lens.</p>
    </section>
    {slugs.length === 0 ? <p class="empty-state">No issues yet.</p> : (
      <ul class="archive-list">
        {slugs.map(slug => (
          <li>
            <a href={url(`/archive/${slug}/`)}>
              <span>{slug.replace("-W", " · Week ")}</span>
              <small>Open issue</small>
            </a>
          </li>
        ))}
      </ul>
    )}
    <footer class="footer">
      <span>Curated by Octozine</span>
      <span>Archive</span>
    </footer>
  </main>
</body>
</html>
