---
interface SummarizedItem {
  owner: string;
  repo: string;
  description: string;
  stars: number;
  starsDelta?: number;
  score?: number;
  language?: string;
  topics?: string[];
  sources: string[];
  url: string;
  summary: { zh: string; en: string };
  reason: string;
  matchedThemes?: string[];
  matchedLanguages?: string[];
}
interface Props {
  item: SummarizedItem;
  languages: string[];
}
const { item, languages } = Astro.props;
const showZh = languages.includes("zh");
const showEn = languages.includes("en");
const matched = [
  ...(item.matchedThemes ?? []),
  ...(item.matchedLanguages ?? []),
].slice(0, 4);
---
<section class="hero">
  <p class="kicker">本周特别推荐 · Featured</p>
  <span class="hero-handle">{item.owner}/{item.repo}</span>
  <h1 class="hero-title">
    <a href={item.url}>{item.repo}</a>
  </h1>
  <p class="hero-sub">{item.description || `${item.owner}/${item.repo}`}</p>
  <div class="meta-line">
    <span>★ {item.stars.toLocaleString()}</span>
    {item.starsDelta !== undefined && <span class="up">↑ {item.starsDelta.toLocaleString()}</span>}
    {item.language && <span>{item.language}</span>}
    <span class="src">via {item.sources.join(" · ")}</span>
  </div>
  {showZh && <p class="body zh">{item.summary.zh}</p>}
  {showEn && <p class="body en">{item.summary.en}</p>}
  {item.reason && (
    <blockquote class="reason">
      <p>{item.reason}</p>
      {matched.length > 0 && (
        <p class="reason-match">{matched.join(" · ")}</p>
      )}
    </blockquote>
  )}
</section>
